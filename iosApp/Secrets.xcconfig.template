// Copy to Secrets.xcconfig and fill in real values.
// NOTE: Use $() to escape // in URLs — xcconfig treats // as a comment.
PROXY_URL = https:/$()/YOUR_CLOUD_FUNCTION_URL_HERE
PROXY_API_KEY = YOUR_API_KEY_HERE

// Meta / Facebook SDK
FB_APP_ID = YOUR_FB_APP_ID_HERE
FB_CLIENT_TOKEN = YOUR_FB_CLIENT_TOKEN_HERE
